# Telegram
BOT_TOKEN=__PUT_TELEGRAM_BOT_TOKEN_HERE__

# App
LOG_LEVEL=INFO
USE_AI_MANAGER=true

# Azure OpenAI via Azure AI Foundry (OpenAI SDK, v1 endpoint)
# Example: https://ai-foodbo-dev.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=__PUT_AZURE_OPENAI_V1_BASE_URL_HERE__

# API key from Azure AI Foundry / Azure OpenAI
AZURE_OPENAI_API_KEY=__PUT_AZURE_OPENAI_API_KEY_HERE__

# Deployment name (NOT marketing model family label)
# Example: gpt-5.2-chat
AZURE_OPENAI_DEPLOYMENT=__PUT_DEPLOYMENT_NAME_HERE__

# Optional model defaults (kept for future usage/tuning)
AZURE_OPENAI_TEMPERATURE=0.15
AZURE_OPENAI_MAX_TOKENS=450